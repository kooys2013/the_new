            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/drift-sentinel.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/oasdiff-drift.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pytestarch-guard.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cpcv-check.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/2604181802_lesson-reinforcer.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/dependency-drift-monitor.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/verify-static.sh",
            "statusMessage": "정적 검증 (py_compile)...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/verify-suggest.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/coverage-gate.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/trajectory-recorder.sh PostToolUse",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/anti-pattern-blocker.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/surprise-detector.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/risk-asset-router.sh",
            "async": true
          }
        ]
