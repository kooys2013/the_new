          {
            "type": "command",
            "command": "bash ~/.claude/hooks/verify-suggest.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/coverage-gate.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/trajectory-recorder.sh PostToolUse",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/anti-pattern-blocker.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/surprise-detector.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/risk-asset-router.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/typecheck.sh",
            "statusMessage": "TypeScript 타입체크 중...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/security-scan.sh",
