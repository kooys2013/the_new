{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_USAGE_GATE_ENABLED": "true",
    "CLAUDE_OPUS_LIMIT_5H": "80",
    "CLAUDE_FALLBACK_MODEL_5H": "sonnet",
    "CLAUDE_OPUS_LIMIT_7D": "80",
    "CLAUDE_FALLBACK_MODEL_7D": "sonnet",
    "CLAUDE_USAGE_CACHE_TTL": "60",
    "CLAUDE_OBS_DIR": "",
    "CLAUDE_DRIFT_DIR": "",
    "CLAUDE_HOOK_RAM_LIMIT_GB": "4",
    "OTEL_SERVICE_NAME": "claude-code-mgtg",
    "COVERAGE_BRANCH_TARGET_A": "95",
    "COVERAGE_BRANCH_TARGET_C": "80",
    "COVERAGE_GATE_SKIP_PATTERN": "backtest_engine\\.py$",
    "MUTATION_SCORE_TARGET_A": "80",
    "MUTATION_SCORE_TARGET_B": "70",
    "FUZZ_DEFAULT_EXAMPLES": "100",
    "MULTI_JUDGE_DEFAULT": "J1+J3",
    "DEB_AUTO_BUNDLE": "1",
    "CLAUDE_VERIFY_DAILY_BUDGET_USD": "5",
    "CLAUDE_STOP_VERIFIER_ENABLED": "0",
    "TRAJECTORY_RECORDER_ENABLED": "1",
    "LLM_EVAL_AUTO_CI": "1",
    "AUTO_MUTATION_ENABLED": "0",
    "AUTO_APPLY_RATE_TARGET": "30",
    "ASSET_BLOAT_WARN_THRESHOLD": "180",
    "ASSET_BLOAT_CRITICAL_THRESHOLD": "200",
    "DECISION_JOURNAL_TRADING_BLOCK": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit(**/*)",
      "Write(**/*)",
      "Read(**/*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Agent(*)",
      "PowerShell(*)"
    ],
    "deny": [],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"C:/Users/koo-ys/workspaces/INSIGHT/.claude/hooks/start-servers.sh\"",
            "statusMessage": "INSIGHT 서버 상태 확인 중...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-briefing.sh",
            "statusMessage": "세션 브리핑 준비 중..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/codex-usage-tracker.sh",
            "statusMessage": "Codex 사용량 확인 중..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/stale-drawer-detector.sh",
            "statusMessage": "Stale drawer 검사 중...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/trace-context-boot.sh",
            "statusMessage": "OTel 컨텍스트 초기화 중...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/drift-baseline-loader.sh",
            "statusMessage": "Drift baseline 로드 중...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/2604181800_daily-fit-check.sh",
            "statusMessage": "Daily Fit Layer 1 체크 중...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/vibe-sunsang-autostart.sh",
            "statusMessage": "바선생 대화 로그 변환 중..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cleanup-old-plans.sh",
            "statusMessage": "오래된 plan 아카이브 정리 중...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/2605011252_ritual-enforcer.sh",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/slack-notify.sh requesting-permission"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/2604191800_prompt-refiner.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cynefin-router.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/devils-advocate-trigger.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/harsh-critic-stop.sh",
            "statusMessage": "Harsh Critic 완료 체크 중..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/stop-codex-bg.sh",
            "statusMessage": "Codex 리뷰 대기 마커 생성 중...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/slack-notify.sh completed"
          },
          {
            "type": "command",
            "command": "bash ~/.mempalace/hooks/mistake_detector_hook.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/ux-rehearsal-suggest.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/harness-session-collector.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/stop-verifier-subagent.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/trajectory-recorder.sh Stop",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/dora-metrics-collector.sh",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.mempalace/hooks/mempal_precompact_hook.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/precompact-decision-extractor.sh",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/global-careful.sh",
            "statusMessage": "파괴적 명령 검사 중..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/typecheck.sh",
            "statusMessage": "TypeScript 타입체크 중...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/security-scan.sh",
            "statusMessage": "보안 스캔 중...",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/lore-commit-suggest.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/drift-sentinel.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/oasdiff-drift.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pytestarch-guard.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cpcv-check.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/2604181802_lesson-reinforcer.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/dependency-drift-monitor.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/verify-static.sh",
