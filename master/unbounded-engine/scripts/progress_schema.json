{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OneShot Dev v2 Progress",
  "type": "object",
  "required": ["task_name", "current_phase", "total_phases", "phases"],
  "properties": {
    "task_name": { "type": "string" },
    "branch": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "current_phase": { "type": "integer", "minimum": 0 },
    "total_phases": { "type": "integer", "minimum": 1 },
    "spec_files": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Phase 1에서 업데이트할 스펙 파일들"
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "status", "prompt_file"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "status": {
            "enum": ["pending", "running", "completed", "failed"]
          },
          "prompt_file": {
            "type": "string",
            "description": ".oneshot/phases/ 하위 상대 경로"
          },
          "context_files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "expected_outputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "start_time": { "type": ["string", "null"] },
          "end_time": { "type": ["string", "null"] },
          "error": { "type": ["string", "null"] },
          "commit_sha": { "type": ["string", "null"] }
        }
      }
    }
  }
}
